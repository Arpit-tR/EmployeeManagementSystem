@model IEnumerable<EmployeeManagementSystem.Models.Employee>

@{
    ViewData["Title"] = "Employee";
}
<h1>Employees</h1>

<form asp-action="Index" method="get" class="mb-3">
    <div class="row">
        <div class="col-md-4">
            <input type="text"
                   name="searchString"
                   class="form-control"
                   placeholder="Search by employee name" />
        </div>

        <div class="col-md-4">
            <input type="submit"
                   value="Search"
                   class="btn btn-primary" />

            <a asp-action="Index"
               class="btn btn-secondary">
                Reset
            </a>
        </div>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-primary">Add Employee</a>
    <a asp-action="GeneratePdf" class="btn btn-success">
        Download PDF Report
    </a>
</p>
<table class="table table-bordered table-striped  ">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Mobile)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Address)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Gender)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.JoiningDate)
            </th>
            <th>
                Department
            </th>
            
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Name)
            </td>
            <td>
                @Html.DisplayFor(model => item.Email)
            </td>
            <td>
                @Html.DisplayFor(model => item.Mobile)
            </td>
            <td>
                @Html.DisplayFor(model => item.Address)
            </td>
            <td>
                @Html.DisplayFor(model => item.Gender)
            </td>
            <td>
                @Html.DisplayFor(model => item.JoiningDate)
            </td>
            <td>
                    @item.Department?.DepartmentName
            </td>
            
            <td>
                    
                    <a class="btn btn-secondary btn-sm  mb-1 me-1" asp-action="Edit" asp-route-id="@item.EmployeeId">Edit</a>
                    <a class="btn btn-info btn-sm  mb-1 me-1" asp-action="Details" asp-route-id="@item.EmployeeId">Details</a>
                    <a class="btn btn-danger btn-sm  mb-1 me-1" asp-action="Delete" asp-route-id="@item.EmployeeId">Delete</a>
                    
            </td>
            
        </tr>
}
    </tbody>
</table>
