@model EmployeeManagementSystem.Models.Department

@{
    ViewData["Title"] = "Details";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">
            <i class="bi bi-person-circle me-2"></i>Department Details
        </h4>
    </div>

    <hr />
    <dl class=" card-body">

        <dt class="col-sm-5">
            @Html.DisplayNameFor(model => model.DepartmentName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DepartmentName)
        </dd>

        <dt class="col-sm-5">
            @Html.DisplayNameFor(model => model.ManagerName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ManagerName)
        </dd>

    </dl>
    <div class="card-footer bg-light text-end">
        <a asp-action="Edit" asp-route-id="@Model.DepartmentId" class="btn btn-warning btn-sm">
            <i class="bi bi-pencil-square"></i> Edit
        </a>
        <a asp-action="Index" class="btn btn-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>
